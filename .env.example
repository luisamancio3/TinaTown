# ── Redis (Upstash) — personagens e placares ──────────────
# Sem estas variaveis em dev, o site usa um armazenamento local
# em arquivo (.data/dev-redis.json). Em producao sao obrigatorias.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Admin ──────────────────────────────────────────────────
# Senha da pagina /admin. Em dev, se vazio, a senha e "dev".
ADMIN_SECRET=

# ── Contadores da live (StreamElements) ────────────────────
SE_CHANNEL_ID=
# opcional: lista de comandos, ex: "arroto,peido,tombo"
SE_COUNTER_COMMANDS=

# ── Backup dos personagens no GitHub ───────────────────────
# Fine-grained PAT com permissao "Contents: read and write" no repo.
# Com isso configurado, cada aprovacao salva um snapshot em
# data/characters-backup.json no repo, restauravel pelo /admin.
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO=luisamancio3/TinaTown
GITHUB_BACKUP_BRANCH=main
